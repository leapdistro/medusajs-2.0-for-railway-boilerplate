{
  "name": "medusa-2.0-boilerplate-backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 2.0 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build && node src/scripts/postBuild.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:mbs": "medusa exec ./src/scripts/seed-mbs.ts",
    "seed:flower-categories": "medusa exec ./src/scripts/seed-flower-categories.ts",
    "seed:preroll-categories": "medusa exec ./src/scripts/seed-preroll-categories.ts",
    "seed:customer-groups": "medusa exec ./src/scripts/seed-customer-groups.ts",
    "create:approved-customer": "medusa exec ./src/scripts/create-approved-customer.ts",
    "wipe:receiving": "medusa exec ./src/scripts/wipe-receiving.ts",
    "wipe:orphan-receivings": "medusa exec ./src/scripts/wipe-orphan-receivings.ts",
    "fix:variant-weights": "medusa exec ./src/scripts/fix-variant-weights.ts",
    "seed:us": "medusa exec ./src/scripts/seed-us.ts",
    "seed:fix-prices": "medusa exec ./src/scripts/fix-prices.ts",
    "seed:fix-shipping-prices": "medusa exec ./src/scripts/fix-shipping-prices.ts",
    "seed:inventory": "medusa exec ./src/scripts/seed-inventory.ts",
    "wipe:catalog": "medusa exec ./src/scripts/wipe-catalog.ts",
    "link:shipping-profile": "medusa exec ./src/scripts/link-shipping-profile.ts",
    "inspect:cart": "medusa exec ./src/scripts/inspect-cart.ts",
    "inspect:products": "medusa exec ./src/scripts/inspect-products.ts",
    "inspect:keys": "medusa exec ./src/scripts/inspect-keys.ts",
    "test:store-products": "medusa exec ./src/scripts/test-store-products.ts",
    "test:email": "medusa exec ./src/scripts/test-email.ts",
    "seed:settings": "medusa exec ./src/scripts/seed-settings.ts",
    "test:anthropic": "medusa exec ./src/scripts/test-anthropic.ts",
    "test:extract": "medusa exec ./src/scripts/test-extract.ts",
    "test:coa-extract": "medusa exec ./src/scripts/test-coa-extract.ts",
    "ib": "init-backend",
    "start": "init-backend && cd .medusa/server && medusa start --verbose",
    "dev": "medusa develop",
    "email:dev": "email dev --dir=./src/modules/email-notifications/templates --port=3002"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/admin-shared": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/dashboard": "2.13.6",
    "@medusajs/draft-order": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/notification-sendgrid": "2.13.6",
    "@medusajs/payment-stripe": "2.13.6",
    "@medusajs/ui": "4.1.6",
    "@medusajs/workflow-engine-redis": "2.13.6",
    "@react-email/components": "^1.0.1",
    "@rokmohar/medusa-plugin-meilisearch": "1.3.5",
    "medusajs-launch-utils": "0.0.18",
    "minio": "^8.0.6",
    "multer": "2.0.2",
    "resend": "4.0.1",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@react-email/preview-server": "^5.1.0",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.5.8",
      "protobufjs": "7.5.5"
    }
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
